{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "appsettings": {
    "logwriters": "jumptest.LogFileWriter,jumptest.LogTableWriter,jumptest.LogConsoleWriter",
    "loglevel": "debug"
  },
  "Auth0": {
    "Domain":   "",
    "Audience": "https://jumptest-scheduler"
  },
  "M2MClients": {
    "ScriptAgent": {
      "TokenEndpoint": "https:///oauth/token",
      "ClientId":      "SCHEDULER_M2M_CLIENT_ID",
      "ClientSecret":  "SCHEDULER_M2M_CLIENT_SECRET",
      "Audience":      "https://jumptest-scriptagent"
    }
  }
}
