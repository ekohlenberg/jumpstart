	private async Task SetEnumProperty(System.Reflection.PropertyInfo propInfo, string value)
	{
		if (long.TryParse(value, out var longValue))
		{
			propInfo.SetValue(onfailure, longValue);
			await InvokeAsync(StateHasChanged);
		}
	}
