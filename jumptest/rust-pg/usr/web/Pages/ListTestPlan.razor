@* Custom Test Plans page (hand-written; usr/web/pages).
   Route is /usr/testplan, which the test_plan table's URI in the metadata points
   the nav menu at; the generated list page keeps its default /testplan route.
   Mirrors the ListWorkflowCore convention: a DataTableContextMenu whose
   right-click menu invokes a custom operation (here, Generate) that creates a
   new Test Run for the plan plus one Unexecuted Test Result per Test Case.
   This file lives outside the generated tree, so it declares its own usings. *@
@page "/usr/testplan"
@using System.Net.Http
@using System.Net.Http.Json
@using System.Collections.Generic
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using jumptest
@using jumptest.Components
@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<PageTitle>Test Plans</PageTitle>

<h1>Test Plans</h1>
<p>Right-click a plan and choose <strong>Generate</strong> to create a new Test Run with one Unexecuted result per test case.</p>

@if (plans == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <DataTableContextMenu Data="@plans"
                          DataType="typeof(TestPlanView)"
                          ShowActions="true"
                          ShowAddButton="true"
                          OnEdit="@OnEditTestPlan"
                          OnAdd="@OnAddTestPlan"
                          ContextMenuItems="@_contextMenuItems" />
}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-info">@message</div>
}

@code {
    private TestPlanView[]? plans;
    private string? message;
    private List<DataTableContextMenu.ContextMenuItem> _contextMenuItems = new();

    protected override void OnInitialized()
    {
        // Right-click context menu items (same convention as ListWorkflowCore).
        _contextMenuItems = new List<DataTableContextMenu.ContextMenuItem>
        {
            new DataTableContextMenu.ContextMenuItem { Label = "Generate", Action = Generate }
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadPlans();
    }

    private async Task LoadPlans()
    {
        try
        {
            var client = ClientFactory.CreateClient("RemoteAPI");
            plans = await client.GetFromJsonAsync<TestPlanView[]>("api/testplan");
        }
        catch (Exception ex)
        {
            message = $"Error loading test plans: {ex.Message}";
        }
    }

    // Context-menu action: create a Test Run + Unexecuted results for the plan
    // via the custom endpoint (usr/server/api/user_api.rs -> TestPlanLogic::generate).
    private async Task Generate(long planId)
    {
        message = null;
        try
        {
            var client = ClientFactory.CreateClient("RemoteAPI");
            var response = await client.PostAsync($"api/testplan/generate/{planId}", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<GenerateResult>();
                message = $"Plan {planId}: created Test Run {result?.test_run_id ?? 0}.";
            }
            else
            {
                message = $"Plan {planId}: generate failed (HTTP {(int)response.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            message = $"Plan {planId}: error - {ex.Message}";
        }
        await InvokeAsync(StateHasChanged);
    }

    async Task OnAddTestPlan()
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        Navigation.NavigateTo($"edit-testplan?returnUrl={Uri.EscapeDataString(currentPath)}");
    }

    async Task OnEditTestPlan(object item)
    {
        var plan = (TestPlanView)item;
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        Navigation.NavigateTo($"edit-testplan/{plan.id}?returnUrl={Uri.EscapeDataString(currentPath)}");
    }

    public class GenerateResult
    {
        public long test_plan_id { get; set; }
        public long test_run_id { get; set; }
    }
}
