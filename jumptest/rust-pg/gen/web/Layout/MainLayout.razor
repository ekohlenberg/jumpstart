@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@using System.Net.Http;
@using System.Net.Http.Json;
@using Microsoft.Extensions.DependencyInjection;
@inject IHttpClientFactory ClientFactory
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
<div class="page">
    <div class="sidebar">
        <div class="top-row ps-3 navbar navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand" href="">jumptest</a>
            </div>
        </div>


        <NavMenuLayout SelectedParentId="@selectedParentId" />
    </div>

    <main>
        <!-- Parent Navigation Menu - Top Row -->
        <div class="top-row px-4">
            <nav class="nav nav-pills">
                <button class="nav-link" @onclick="@(() => NavigationManager.NavigateTo("/"))">
                    <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
                </button>
                @if (isMenuLoading)
                {
                    <p><em>Loading menu...</em></p>
                }
                else if (menuError != null)
                {
                    <p class="text-danger small">@menuError</p>
                }
                else if (navMenuList != null)
                {
                    @foreach (var navMenu in navMenuList)
                    {
                        <div class="nav-item">
                            <button class="nav-link @(selectedParent == navMenu.name ? "active" : "")" @onclick="@(() => SelectParent(navMenu.name))">
                                <span class="bi bi-folder-fill" aria-hidden="true"></span> @navMenu.name
                            </button>
                        </div>
                    }
                }
            </nav>

            @* Authentication disabled: <LoginDisplay /> removed until Auth0 is re-enabled. *@
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private string? selectedParent = null;
    private long? selectedParentId = null;
    protected NavMenu[]? navMenuList;
    private bool isMenuLoading = false;
    private string? menuError = null;

    protected override async Task OnInitializedAsync()
    {
        // Authentication disabled: load the menu unconditionally.
        await LoadMenuAsync();
    }

    private async Task LoadMenuAsync()
    {
        isMenuLoading = true;
        menuError = null;
        try
        {
            var remoteClient = ClientFactory.CreateClient("RemoteAPI");
            navMenuList = await remoteClient.GetFromJsonAsync<NavMenu[]>("api/navmenu/byparent?parent_id=0&orderby=ordinal");
        }
        catch (Exception ex)
        {
            menuError = $"Menu error: {ex.Message}";
        }
        finally
        {
            isMenuLoading = false;
        }
    }

    private void SelectParent(string parent)
    {
        selectedParent = parent;
        selectedParentId = navMenuList?.FirstOrDefault(n => n.name == parent)?.id;
    }
}
