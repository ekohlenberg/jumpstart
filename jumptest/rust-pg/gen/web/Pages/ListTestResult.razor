@page "/testresult"
@using System.Collections.Generic;
@using jumptest.Components;
@inject HttpClient Http
@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))


<PageTitle>Test Result</PageTitle>

<h1>Test Result</h1>

<p>This component demonstrates fetching Test Result data from the server.</p>

@if (testresultList == null)
{
    <p><em>Loading...</em></p>
}
else
{
    Console.WriteLine($"ListTemplate: About to render DataTable with {@testresultList.Length} items");
 
    
    <DataTable Data="@testresultList" 
               DataType="typeof(TestResultView)" 
               ShowActions="true" 
               ShowAddButton="true"
               OnEdit="@OnEditTestResult"
               OnAdd="@OnAddTestResult" />
    
    Console.WriteLine($"ListTemplate: DataTable rendered");
}

@code {
    protected  TestResultView[]? testresultList;
    // Real-time updates arrive over Server-Sent Events (see wwwroot/js/notifications.js).
    private IJSObjectReference? _sseHandle;
    private IDisposable? _sseRef;
    private string _domainObjectName = "TestResult";
    private Dictionary<string, Dictionary<long, string>> enumData = new Dictionary<string, Dictionary<long, string>>();

    protected override async Task OnInitializedAsync()
    {
        var remoteClient = ClientFactory.CreateClient("RemoteAPI");

        testresultList = await remoteClient.GetFromJsonAsync<TestResultView[]>("api/testresult");
        
        Console.WriteLine($"ListTemplate: Loaded {testresultList?.Length ?? 0} testresult records");
        if (testresultList != null && testresultList.Length > 0)
        {
            Console.WriteLine($"ListTemplate: First item type: {testresultList[0].GetType().Name}");
        }

        await ConnectNotifications();
        await InitEnumData();
    }

    // Open the SSE notification stream. The browser's EventSource (via the JS
    // interop) handles reconnection on its own. Every "PropertyUpdated" event is
    // routed back to OnPropertyUpdated below.
    private async Task ConnectNotifications()
    {
        try
        {
            var remoteClient = ClientFactory.CreateClient("RemoteAPI");
            var baseAddress = remoteClient.BaseAddress?.ToString() ?? "http://localhost:5200";
            var streamUrl = $"{baseAddress.TrimEnd('/')}/api/Notification/stream";

            _sseRef = DotNetObjectReference.Create(this);
            _sseHandle = await JS.InvokeAsync<IJSObjectReference>("jumpstartSse.connect", streamUrl, _sseRef);
            Console.WriteLine($"ListTemplate: SSE notification stream connected for {_domainObjectName}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ListTemplate: Error connecting notification stream: {ex.Message}");
        }
    }

    // Invoked from JS for every "PropertyUpdated" SSE event. Filters to this
    // page's domain object, then updates the affected row in place.
    [JSInvokable]
    public async Task OnPropertyUpdated(string json)
    {
        try
        {
            var message = System.Text.Json.JsonSerializer.Deserialize<PropertyUpdateMessage>(
                json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (message != null && message.DomainObjectName == _domainObjectName)
            {
                Console.WriteLine($"ListTemplate: Received update for {message.DomainObjectName}[{message.InstanceId}]");
                await HandlePropertyUpdate(message);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ListTemplate: Error handling notification: {ex.Message}");
        }
    }

    private async Task InitEnumData()
    {
        var remoteClient = ClientFactory.CreateClient("RemoteAPI");

                var enumtest_result_status_idResult = await remoteClient.GetFromJsonAsync<List<EnumHelper>>($"api/testresultstatus/enum");
                if (enumtest_result_status_idResult != null)
                {
                    enumData["test_result_status_id"] = enumtest_result_status_idResult.ToDictionary(e => e.id, e => e.rwkString);
                }
                 }

    private async Task HandlePropertyUpdate(PropertyUpdateMessage message)
    {
        try
        {
            if (testresultList == null)
            {
                return;
            }

            // Find the item in the list by ID
            var index = Array.FindIndex(testresultList, item => item.id == message.InstanceId);
            
            if (index >= 0)
            {
                // Fetch the updated item from the API to ensure we have the complete View object
                // with all computed properties and enum display values properly populated
                var remoteClient = ClientFactory.CreateClient("RemoteAPI");
                var updatedObject = await remoteClient.GetFromJsonAsync<TestResultView>($"api/testresult/view/{message.InstanceId}");
                if (updatedObject != null)
                { 

                        //if (enumData.ContainsKey("test_result_status_id") && enumData["test_result_status_id"].ContainsKey(updatedObject.test_result_status_id))
                        //updatedObject.test_result_status_name = enumData["test_result_status_id"][updatedObject.test_result_status_id];
                        
               
                    // Update existing item with the fetched object (enum display values are already set by the API)
                    testresultList[index] = updatedObject;
                    Console.WriteLine($"ListTemplate: Updated {_domainObjectName}[{message.InstanceId}] in list from API");
                    
                    // Notify UI to update
                    await InvokeAsync(StateHasChanged);
                }
            }
            else
            {
                // Item not found, might be a new item - reload the list
                Console.WriteLine($"ListTemplate: {_domainObjectName}[{message.InstanceId}] not found in list, reloading...");
                await ReloadList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ListTemplate: Error handling property update: {ex.Message}");
            // On error, fall back to reloading the entire list
            try
            {
                await ReloadList();
            }
            catch (Exception reloadEx)
            {
                Console.WriteLine($"ListTemplate: Error reloading list: {reloadEx.Message}");
            }
        }
    }

    private async Task ReloadList()
    {
        try
        {
            var remoteClient = ClientFactory.CreateClient("RemoteAPI");
            testresultList = await remoteClient.GetFromJsonAsync<TestResultView[]>("api/testresult");
            Console.WriteLine($"ListTemplate: Reloaded {testresultList?.Length ?? 0} testresult records");
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"ListTemplate: Error reloading list: {ex.Message}");
        }
    }

    async Task OnAddTestResult()
    {
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        Navigation.NavigateTo($"edit-testresult?returnUrl={Uri.EscapeDataString(currentPath)}");
    }

    async Task OnEditTestResult(object item)
    {
        var testresult = (TestResultView)item;
        var currentPath = new Uri(Navigation.Uri).AbsolutePath;
        Navigation.NavigateTo($"edit-testresult/{testresult.id}?returnUrl={Uri.EscapeDataString(currentPath)}");
    }

    public async ValueTask DisposeAsync()
    {
        if (_sseHandle is not null)
        {
            try
            {
                await _sseHandle.InvokeVoidAsync("close");
                await _sseHandle.DisposeAsync();
                Console.WriteLine($"ListTemplate: SSE notification stream closed");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"ListTemplate: Error closing notification stream: {ex.Message}");
            }
        }
        _sseRef?.Dispose();
    }

    // Message structure for property update notifications (matches server-side PropertyUpdateMessage)
    private class PropertyUpdateMessage
    {
        public string DomainObjectName { get; set; } = string.Empty;
        public long InstanceId { get; set; }
        public string JsonData { get; set; } = string.Empty;
        public DateTime Timestamp { get; set; }
    }
}
