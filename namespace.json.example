{
  "namespace": "my-app",
  "datasources": {
    "default": {
      "dbtype": "postgresql",
      "hostname": "localhost",
      "port": "5432",
      "database": "my_app",
      "username": "my_app_user",
      "password": "change-me"
    }
  },
  "loglevel": "debug",
  "logwriters": "console,file",
  "auth0": {
    "domain": "your-tenant.us.auth0.com",
    "audience": "https://my-app-api"
  }
}
