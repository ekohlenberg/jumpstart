	// Display text for global/audit fields (see ReflectionHelper.IsGlobalProperty
	// above) -- same value as GetStringProperty, with a friendlier Yes/No for
	// boolean columns like is_active.
	private string GetReadOnlyDisplayValue(System.Reflection.PropertyInfo propInfo)
	{
		var underlyingType = Nullable.GetUnderlyingType(propInfo.PropertyType) ?? propInfo.PropertyType;
		if (underlyingType == typeof(bool))
		{
			return GetBoolProperty(propInfo) ? "Yes" : "No";
		}
		return GetStringProperty(propInfo);
	}

