	// Flips one option's checked state within a map-relationship checklist --
	// shared by every Create{other}_{role}_MapTabContent() above. Mirrors
	// toggleMapChecked in web/nodejs/src/pages/Edittemplate.tsx.cshtml.
	private async Task ToggleMapChecked(HashSet<long> checkedSet, long optionId, bool isChecked)
	{
		if (isChecked)
		{
			checkedSet.Add(optionId);
		}
		else
		{
			checkedSet.Remove(optionId);
		}
		await InvokeAsync(StateHasChanged);
	}

	async Task HandleSubmit(EditContext context)
	{
		if (context.Validate())
		{
			try
			{
				var remoteClient = ClientFactory.CreateClient("RemoteAPI");
				if (id is null)
				{
					// Create new record
					var response = await remoteClient.PostAsJsonAsync($"api/@(Model.DomainVar)", @(Model.DomainVar));
					if (response.IsSuccessStatusCode)
					{
						var createdObj = await response.Content.ReadFromJsonAsync<@(Model.DomainObj)>();
						if (createdObj != null)
						{
							@(Model.DomainVar) = createdObj;
						}
					}
				}
				else
				{
					// Update existing record
					await remoteClient.PutAsJsonAsync($"api/@(Model.DomainVar)/{id}", @(Model.DomainVar));

					// Apply every map-relationship checklist alongside the object
					// save -- only meaningful for an existing record, since a
					// brand-new record has no checklist to have edited yet
					// (mirrors the Delete button, and the child-relationship
					// tabs, which are likewise only loaded once id is known).
@{
	foreach (var map in mapRelationships)
	{
		var otherDomainVar = map.OtherObject.DomainVar;
		var role = map.Role;
		var otherLabel = map.OtherObject.Label;

		<text>
					try
					{
						await remoteClient.PutAsJsonAsync($"api/@(Model.DomainVar)/{id}/map/@(otherDomainVar)_@(role)", @(otherDomainVar)_@(role)_Checked.ToList());
					}
					catch (Exception mapEx)
					{
						Console.WriteLine($"Error saving @(otherLabel) map: {mapEx.Message}");
					}
		</text>
	}
}
				}
			}
			catch (Exception ex)
			{
				Console.WriteLine($"Error saving @(Model.DomainVar): {ex.Message}");
			}
		}

		// Navigate back to list after successful save
		Navigation.NavigateTo(_returnUrl ?? "/@(Model.DomainVar)");
	}

	void Cancel()
	{
		Navigation.NavigateTo(_returnUrl ?? "/@(Model.DomainVar)");
	}

	async Task HandleDelete()
	{
		if (id is null)
		{
			return;
		}

		// Plain browser confirm() via JS interop -- matches window.confirm in
		// web/nodejs/src/pages/Edittemplate.tsx.cshtml's handleDelete, so both
		// clients behave identically.
		bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete this @(Model.Label)? This cannot be undone.");
		if (!confirmed)
		{
			return;
		}

		try
		{
			var remoteClient = ClientFactory.CreateClient("RemoteAPI");
			await remoteClient.DeleteAsync($"api/@(Model.DomainVar)/{id}");
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error deleting @(Model.DomainVar): {ex.Message}");
			return;
		}

		Navigation.NavigateTo(_returnUrl ?? "/@(Model.DomainVar)");
	}

