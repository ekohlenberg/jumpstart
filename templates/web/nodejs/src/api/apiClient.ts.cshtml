// The Node/React analogue of Blazor's named "RemoteAPI" HttpClient
// (builder.Services.AddHttpClient("RemoteAPI", ...).AddHttpMessageHandler(...)):
// a single fetch wrapper, scoped to the app via React context, that prefixes
// every call with the configured apiBaseUrl and attaches the Auth0 access
// token as a Bearer header, the same way AuthorizationMessageHandler does.
import { createContext, useContext, useMemo, type ReactNode } from "react";
import { useAuth0 } from "@@auth0/auth0-react";

export interface ApiClient {
  get<T>(path: string): Promise<T>;
  post<T>(path: string, body: unknown): Promise<T>;
  put<T>(path: string, body: unknown): Promise<T>;
  del(path: string): Promise<void>;
}

function createApiClient(baseUrl: string, getAccessToken: () => Promise<string>): ApiClient {
  async function request<T>(path: string, init?: RequestInit): Promise<T> {
    const token = await getAccessToken();
    const response = await fetch(`${baseUrl}${path}`, {
      ...init,
      headers: {
        ...(init?.body ? { "Content-Type": "application/json" } : {}),
        Authorization: `Bearer ${token}`,
        ...(init?.headers ?? {}),
      },
    });

    if (!response.ok) {
      throw new Error(`${init?.method ?? "GET"} ${path} failed: ${response.status} ${response.statusText}`);
    }

    if (response.status === 204) {
      return undefined as T;
    }

    return (await response.json()) as T;
  }

  return {
    get: <T,>(path: string) => request<T>(path),
    post: <T,>(path: string, body: unknown) => request<T>(path, { method: "POST", body: JSON.stringify(body) }),
    put: <T,>(path: string, body: unknown) => request<T>(path, { method: "PUT", body: JSON.stringify(body) }),
    del: (path: string) => request<void>(path, { method: "DELETE" }),
  };
}

const ApiClientContext = createContext<ApiClient | null>(null);

export function ApiClientProvider({
  apiBaseUrl,
  children,
}: {
  apiBaseUrl: string;
  children: ReactNode;
}) {
  const { getAccessTokenSilently } = useAuth0();

  const client = useMemo(
    () => createApiClient(apiBaseUrl, getAccessTokenSilently),
    [apiBaseUrl, getAccessTokenSilently],
  );

  return <ApiClientContext.Provider value={client}>{children}</ApiClientContext.Provider>;
}

export function useApiClient(): ApiClient {
  const client = useContext(ApiClientContext);
  if (!client) {
    throw new Error("useApiClient must be used within an ApiClientProvider");
  }
  return client;
}
