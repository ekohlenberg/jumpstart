// <auto-generated>
// Real-time notification publisher. Mirrors the .NET NotificationRegistrar: an
// after-hook on insert/update/put builds a {DomainObjectName, InstanceId,
// JsonData} message describing an object change.
//
// Delivery has two paths. The node that hosts the SSE endpoint (the API server)
// registers an in-process delivery sink via `set_local_delivery`; its own
// notifications are handed to that sink directly and the HTTP fan-out skips it.
// This avoids a loopback HTTP round-trip to the server's own registered URL —
// and the hostname-resolution fragility that comes with it — for the common
// single-server case. Any *other* online API server found in core.server_node
// (e.g. when a separate scheduler/scriptagent process made the change) still
// receives the change over HTTP at POST /api/Notification/publish, exactly as in
// the .NET version. The transport to the browser is SSE instead of SignalR.
// </auto-generated>

use std::sync::{Mutex, OnceLock};
use std::thread;

use common::Logger;
use domain::server_node_core::{ServerNodeStatus, ServerNodeType};
use persist::DBPersist;

/// In-process delivery callback: (domain_object, instance_id, json_data).
pub type LocalSink = Box<dyn Fn(&str, i64, &str) + Send + Sync>;

fn local_sink() -> &'static Mutex<Option<LocalSink>> {
    static SINK: OnceLock<Mutex<Option<LocalSink>>> = OnceLock::new();
    SINK.get_or_init(|| Mutex::new(None))
}

fn local_url() -> &'static Mutex<Option<String>> {
    static URL: OnceLock<Mutex<Option<String>>> = OnceLock::new();
    URL.get_or_init(|| Mutex::new(None))
}

/// Register this node's own SSE broadcaster (`sink`) and the URL it registered
/// in core.server_node (`self_url`). Notifications are then delivered to `sink`
/// in-process and the HTTP fan-out skips `self_url`, so a single-server setup
/// needs no loopback HTTP and is immune to hostname-resolution problems.
pub fn set_local_delivery(self_url: &str, sink: LocalSink) {
    *local_url().lock().unwrap() = Some(self_url.to_string());
    *local_sink().lock().unwrap() = Some(sink);
    Logger::info(format!("notification: in-process delivery registered for {}", self_url));
}

/// Publish an object-change notification. The local SSE registry (if this node
/// hosts one) is updated synchronously and cheaply; the cross-node HTTP fan-out
/// runs on a background thread so the logic operation and proxy hook chain never
/// block — parity with the .NET fire-and-forget Task.Run.
pub fn publish(domain_object: &str, instance_id: i64, json_data: String) {
    if instance_id == 0 {
        return;
    }

    // Deliver to the in-process SSE registry, if this node hosts one.
    {
        let guard = local_sink().lock().unwrap();
        Logger::info(format!(
            "notification: publish {}[{}] (local sink registered: {})",
            domain_object,
            instance_id,
            guard.is_some()
        ));
        if let Some(sink) = guard.as_ref() {
            sink(domain_object, instance_id, &json_data);
        }
    }

    let domain = domain_object.to_string();
    let self_url = local_url().lock().unwrap().clone();
    thread::spawn(move || {
        let urls = match api_server_urls() {
            Ok(u) => u,
            Err(e) => {
                Logger::error(format!("notification: API server lookup failed: {}", e));
                return;
            }
        };

        let body = serde_json::json!({
            "DomainObjectName": domain,
            "InstanceId": instance_id,
            "JsonData": json_data,
        })
        .to_string();

        for url in urls {
            // Already delivered in-process to this node; don't loop back over HTTP.
            if self_url.as_deref() == Some(url.as_str()) {
                continue;
            }
            let endpoint = format!("{}/api/Notification/publish", url.trim_end_matches('/'));
            match ureq::post(&endpoint)
                .set("Content-Type", "application/json")
                .send_string(&body)
            {
                Ok(_) => Logger::debug(format!(
                    "notification: published {}[{}] to {}",
                    domain, instance_id, url
                )),
                Err(e) => Logger::warning(format!(
                    "notification: publish to {} failed: {}",
                    url, e
                )),
            }
        }
    });
}

/// URLs of all online API-server nodes (parity with NotificationRegistrar's
/// GetApiServerUrls). The set is small and only changes on node restart, so it
/// is queried fresh each time rather than cached.
fn api_server_urls() -> Result<Vec<String>, persist::PersistError> {
    let sql = format!(
        "SELECT * FROM core.server_node \
         WHERE server_node_type_id = {} AND server_node_status_id = {} AND is_active = 1 \
         ORDER BY registered_at DESC",
        ServerNodeType::ApiServer as i64,
        ServerNodeStatus::Online as i64
    );
    let rows = DBPersist::select(&sql, "default")?;
    Ok(rows
        .into_iter()
        .filter_map(|row| match row.get("url") {
            Some(serde_json::Value::String(u)) if !u.is_empty() => Some(u.clone()),
            _ => None,
        })
        .collect())
}
