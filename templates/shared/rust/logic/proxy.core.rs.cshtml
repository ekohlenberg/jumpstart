use std::sync::{Mutex, Once, OnceLock};

use common::Logger;

use crate::base_logic::LogicError;
use crate::op_role_member_logic::OpRoleMemberLogic;

/// A before hook: receives (domain_obj, method_name); may veto with an error.
pub type BeforeAction = Box<dyn Fn(&str, &str) -> Result<(), LogicError> + Send + Sync>;
/// An after hook: receives (domain_obj, method_name); may surface an error.
pub type AfterAction = Box<dyn Fn(&str, &str) -> Result<(), LogicError> + Send + Sync>;

struct Registry {
    before: Vec<BeforeAction>,
    after: Vec<AfterAction>,
}

fn registry() -> &'static Mutex<Registry> {
    static REG: OnceLock<Mutex<Registry>> = OnceLock::new();
    REG.get_or_init(|| Mutex::new(Registry { before: Vec::new(), after: Vec::new() }))
}

/// Thread-safe registry of interception hooks (parity with ProxyAction).
pub struct ProxyAction;

impl ProxyAction {
    pub fn add_before_action(action: BeforeAction) {
        registry().lock().unwrap().before.push(action);
    }

    pub fn add_after_action(action: AfterAction) {
        registry().lock().unwrap().after.push(action);
    }
}

/// Run all before hooks; the first error short-circuits (parity with throw).
pub fn run_before(domain_obj: &str, method: &str) -> Result<(), LogicError> {
    let reg = registry().lock().unwrap();
    for action in reg.before.iter() {
        action(domain_obj, method)?;
    }
    Ok(())
}

/// Run all after hooks; the first error short-circuits.
pub fn run_after(domain_obj: &str, method: &str) -> Result<(), LogicError> {
    let reg = registry().lock().unwrap();
    for action in reg.after.iter() {
        action(domain_obj, method)?;
    }
    Ok(())
}

/// Install the default hooks exactly once per process (parity with
/// Proxy.Initialize + ProxyCallbackInitializer.Initialize).
pub fn initialize() {
    static INIT: Once = Once::new();
    INIT.call_once(|| {
        // Logging before action.
        ProxyAction::add_before_action(Box::new(|domain_obj, method| {
            Logger::info(format!("Invoking {}.{}.", domain_obj, method));
            Ok(())
        }));

        // Authorization before action.
        ProxyAction::add_before_action(Box::new(|domain_obj, method| {
            let user = OpRoleMemberLogic::current_user();
            Logger::debug(format!(
                "Checking {} authorization for {}.{}.",
                user, domain_obj, method
            ));
            match OpRoleMemberLogic::authorized(domain_obj, method) {
                Ok(true) => Ok(()),
                Ok(false) => Err(LogicError::Unauthorized(format!(
                    "Principal {} is not authorized for {}.{}.",
                    user, domain_obj, method
                ))),
                Err(e) => Err(LogicError::Persist(e)),
            }
        }));

        // Logging after action.
        ProxyAction::add_after_action(Box::new(|_domain_obj, method| {
            Logger::info(format!("After invoking {}.", method));
            Ok(())
        }));

        // TODO: pre/post event-service hooks (EventServiceLogic) — deferred
        // until the script-execution engine is ported.
    });
}
