// Dispatch by object name to that object's `<Obj>Logic::exec`. The name is
// matched case-insensitively against both the PascalCase domain name and the
// snake_case table name, so the same entry point serves the REST API (whose
// routes are case-insensitive) and the script engine. Rust has no reflection,
// so the generator emits the match.
// </auto-generated>

use serde_json::Value;

use crate::base_logic::LogicError;
use crate::logic_context::LogicContext;

/// Run `method` against the named object's authorized logic entry point.
pub fn object_exec(
    domain_obj: &str,
    method: &str,
    ctx: &mut LogicContext,
) -> Result<Value, LogicError> {
    match domain_obj.to_ascii_lowercase().as_str() {
@foreach (var obj in Model.Objects)
{
    if (obj.DomainVar == obj.TableName)
    {
        <text>
        "@(obj.DomainVar)" => crate::@(obj.DomainObj)Logic::exec(method, ctx),
        </text>
    }
    else
    {
        <text>
        "@(obj.DomainVar)" | "@(obj.TableName)" => crate::@(obj.DomainObj)Logic::exec(method, ctx),
        </text>
    }
}
        _ => Err(LogicError::Event(format!("unknown object '{}'", domain_obj))),
    }
}

