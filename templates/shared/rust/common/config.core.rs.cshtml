/// Application namespace this config crate was generated for.
pub const NAMESPACE: &str = "@Model.Name";

static NAMESPACE_CONFIG: OnceLock<NamespaceConfig> = OnceLock::new();
static CURRENT_DATA_SOURCE: Mutex<Option<String>> = Mutex::new(None);

pub struct Config;

impl Config {
    pub fn current_data_source() -> String {
        CURRENT_DATA_SOURCE
            .lock()
            .unwrap()
            .clone()
            .unwrap_or_else(|| "default".to_string())
    }

    pub fn set_data_source(name: &str) {
        *CURRENT_DATA_SOURCE.lock().unwrap() = Some(name.to_string());
    }

    /// Load and cache the namespace config from the user's home directory.
    pub fn load_namespace_config() -> &'static NamespaceConfig {
        NAMESPACE_CONFIG.get_or_init(|| {
            let home = dirs_home();
            let json_path = home.join(format!(".{}.json", NAMESPACE));
            let legacy_path = home.join(format!(".{}", NAMESPACE));

            if json_path.exists() {
                let content = std::fs::read_to_string(&json_path)
                    .unwrap_or_else(|e| panic!("Unable to read {}: {}", json_path.display(), e));
                let cfg: NamespaceConfig = serde_json::from_str(&content)
                    .unwrap_or_else(|e| panic!("Invalid {}: {}", json_path.display(), e));
                if cfg.datasources.is_empty() {
                    panic!("The .{}.json file contains no data sources.", NAMESPACE);
                }
                cfg
            } else if legacy_path.exists() {
                parse_legacy(&std::fs::read_to_string(&legacy_path).unwrap())
            } else {
                panic!(
                    "Neither .{0}.json nor .{0} was found in the home directory.",
                    NAMESPACE
                );
            }
        })
    }

    pub fn db_type(data_source: &str) -> String {
        let cfg = Self::load_namespace_config();
        cfg.datasources
            .get(data_source)
            .map(|d| d.dbtype.to_lowercase().trim().to_string())
            .filter(|s| !s.is_empty())
            .unwrap_or_else(|| "postgresql".to_string())
    }

    pub fn db_connection() -> String {
        Self::db_connection_for(&Self::current_data_source())
    }

    /// Best-effort read of the `loglevel` / `logwriters` settings from the
    /// namespace config file. Returns `(level, writers)`, either of which may be
    /// `None`. Never panics and never logs â€” it is called from the Logger during
    /// initialization, before logging itself is configured, and may run in
    /// programs (tools, tests) that have no config file at all.
    pub fn log_settings() -> (Option<String>, Option<String>) {
        // If the namespace config has already been loaded for DB access, reuse it.
        if let Some(cfg) = NAMESPACE_CONFIG.get() {
            return (cfg.loglevel.clone(), cfg.logwriters.clone());
        }

        let home = dirs_home();
        let json_path = home.join(format!(".{}.json", NAMESPACE));
        if let Ok(content) = std::fs::read_to_string(&json_path) {
            if let Ok(cfg) = serde_json::from_str::<NamespaceConfig>(&content) {
                return (cfg.loglevel, cfg.logwriters);
            }
        }
        (None, None)
    }

    pub fn db_connection_for(data_source: &str) -> String {
        let cfg = Self::load_namespace_config();
        let ds = cfg
            .datasources
            .get(data_source)
            .unwrap_or_else(|| panic!("Data source '{}' not found in configuration.", data_source));

        let db_type = if ds.dbtype.is_empty() {
            "postgresql".to_string()
        } else {
            ds.dbtype.to_lowercase().trim().to_string()
        };
        let server = none_or(&ds.hostname, "localhost");
        let port = none_or(&ds.port, "5432");
        let database = ds.database.clone();
        let has_creds = !ds.username.is_empty() && !ds.password.is_empty();

        let mut conn = connection_template(&db_type, has_creds)
            .replace("^server", &server)
            .replace("^port", &port)
            .replace("^database", &database);

        if has_creds {
            conn = conn
                .replace("^username", &ds.username)
                .replace("^password", &ds.password);
        }
        conn
    }
}

fn none_or(value: &str, fallback: &str) -> String {
    if value.is_empty() {
        fallback.to_string()
    } else {
        value.to_string()
    }
}

fn connection_template(db_type: &str, include_credentials: bool) -> &'static str {
    match db_type {
        "sqlserver" | "mssql" => {
            if include_credentials {
                "Server=^server,^port;Database=^database;User Id=^username;Password=^password;TrustServerCertificate=true;"
            } else {
                "Server=^server,^port;Database=^database;Trusted_Connection=true;TrustServerCertificate=true;"
            }
        }
        _ => {
            if include_credentials {
                "host=^server port=^port dbname=^database user=^username password=^password"
            } else {
                "host=^server port=^port dbname=^database"
            }
        }
    }
}

fn parse_legacy(content: &str) -> NamespaceConfig {
    let parts: Vec<&str> = content.trim().split(':').collect();
    if parts.len() != 4 && parts.len() != 6 {
        panic!(
            "The .{} file must contain 4 or 6 colon-separated parameters: \
             dbtype:server:port:database[:username:password]",
            NAMESPACE
        );
    }
    let mut datasources = HashMap::new();
    datasources.insert(
        "default".to_string(),
        DataSourceConfig {
            dbtype: parts[0].trim().to_lowercase(),
            hostname: parts[1].trim().to_string(),
            port: parts[2].trim().to_string(),
            database: parts[3].trim().to_string(),
            username: parts.get(4).map(|s| s.trim().to_string()).unwrap_or_default(),
            password: parts.get(5).map(|s| s.trim().to_string()).unwrap_or_default(),
        },
    );
    NamespaceConfig {
        namespace: NAMESPACE.to_string(),
        datasources,
        network_interface: None,
        loglevel: None,
        logwriters: None,
    }
}

fn dirs_home() -> std::path::PathBuf {
    std::env::var_os("HOME")
        .or_else(|| std::env::var_os("USERPROFILE"))
        .map(std::path::PathBuf::from)
        .unwrap_or_else(|| std::path::PathBuf::from("."))
}
