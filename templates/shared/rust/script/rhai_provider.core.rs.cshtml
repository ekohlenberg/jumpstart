// <auto-generated>
// Rhai-backed ScriptProvider. Builds a sandboxed engine, registers the host
// capability surface (logging, HTTP, Logic-routed database access), runs the
// script against the context, and writes results / mutations back.
//
// Capabilities exposed to scripts:
//   log_info(msg) / log_debug(msg) / log_error(msg)
//   http_get(url) -> String        http_post(url, body) -> String
//   db_get(obj, id) -> map|()       db_select(obj) -> [map]
//   db_put(obj, #{...})             db_update(obj, id, #{...})   db_delete(obj, id)
//   ctx   (the triggering record, mutable)        args  (input arguments)
// </auto-generated>

use std::collections::HashMap;

use common::{BaseObject, Logger};
use logic::LogicContext;
use rhai::serde::{from_dynamic, to_dynamic};
use rhai::{Dynamic, Engine, EvalAltResult, Map, Scope};
use serde_json::Value;

use crate::i_script_provider::{ScriptError, ScriptProvider};
use crate::logic_bridge;
use crate::script_context::ScriptContext;

#[derive(Debug, Default, Clone)]
pub struct RhaiProvider;

impl RhaiProvider {
    pub fn new() -> Self {
        RhaiProvider
    }
}

impl ScriptProvider for RhaiProvider {
    fn compile_and_execute(&self, source: &str, ctx: &mut ScriptContext) -> Result<(), ScriptError> {
        if source.trim().is_empty() {
            return Err(ScriptError::Empty("script source is empty".to_string()));
        }

        let engine = build_engine();
        let mut scope = Scope::new();

        // Expose the triggering record as `ctx` and the inputs as `args`.
        let ctx_dyn = to_dynamic(&ctx.transaction.data)
            .map_err(|e| ScriptError::Eval(e.to_string()))?;
        scope.push_dynamic("ctx", ctx_dyn);
        let args_dyn = to_dynamic(&ctx.args).map_err(|e| ScriptError::Eval(e.to_string()))?;
        scope.push_dynamic("args", args_dyn);

        match engine.eval_with_scope::<Dynamic>(&mut scope, source) {
            Ok(result) => {
                if !result.is_unit() {
                    ctx.script_result = from_dynamic::<Value>(&result).ok();
                }
                // Write back any mutations the script made to `ctx`.
                if let Some(map) = scope.get_value::<Map>("ctx") {
                    for (k, v) in map {
                        let jv = from_dynamic::<Value>(&v).unwrap_or(Value::Null);
                        ctx.transaction.set(&k, jv);
                    }
                }
                // Honour an explicit `ret_code` set by the script.
                if let Some(rc) = scope.get_value::<i64>("ret_code") {
                    ctx.ret_code = rc as i32;
                }
                Ok(())
            }
            Err(e) => {
                ctx.ret_code = 1;
                ctx.script_exception = Some(e.to_string());
                Err(ScriptError::Eval(e.to_string()))
            }
        }
    }
}

fn to_err<E: std::fmt::Display>(e: E) -> Box<EvalAltResult> {
    e.to_string().into()
}

/// Build a BaseObject record from a Rhai object map argument.
fn record_from_dynamic(fields: &Dynamic) -> Result<BaseObject, Box<EvalAltResult>> {
    let map: HashMap<String, Value> = from_dynamic(fields)?;
    let mut record = BaseObject::new();
    for (k, v) in map {
        record.set(&k, v);
    }
    Ok(record)
}

fn build_engine() -> Engine {
    let mut engine = Engine::new();
    // Sandbox limits: keep a runaway script from hanging or exhausting memory.
    engine.set_max_operations(5_000_000);
    engine.set_max_call_levels(64);
    engine.set_max_string_size(5_000_000);
    engine.set_max_array_size(100_000);

    // ── logging ─────────────────────────────────────────────────────────
    engine.register_fn("log_info", |m: &str| Logger::info(m));
    engine.register_fn("log_debug", |m: &str| Logger::debug(m));
    engine.register_fn("log_error", |m: &str| Logger::error(m));

    // ── web requests (blocking) ─────────────────────────────────────────
    engine.register_fn("http_get", |url: &str| -> Result<String, Box<EvalAltResult>> {
        ureq::get(url).call().map_err(to_err)?.into_string().map_err(to_err)
    });
    engine.register_fn(
        "http_post",
        |url: &str, body: &str| -> Result<String, Box<EvalAltResult>> {
            ureq::post(url)
                .send_string(body)
                .map_err(to_err)?
                .into_string()
                .map_err(to_err)
        },
    );

    // ── database (through the generated Logic bridge -> <Obj>Logic::exec,
    //    which runs authorization + audit + events) ───────────────────────
    engine.register_fn("db_get", |obj: &str, id: i64| -> Result<Dynamic, Box<EvalAltResult>> {
        let mut ctx = LogicContext::for_id(id);
        let v = logic_bridge::exec(obj, "get", &mut ctx).map_err(to_err)?;
        if v.is_null() {
            Ok(Dynamic::UNIT)
        } else {
            to_dynamic(&v)
        }
    });
    engine.register_fn("db_select", |obj: &str| -> Result<Dynamic, Box<EvalAltResult>> {
        let mut ctx = LogicContext::new();
        let v = logic_bridge::exec(obj, "select", &mut ctx).map_err(to_err)?;
        to_dynamic(&v)
    });
    engine.register_fn("db_put", |obj: &str, fields: Dynamic| -> Result<Dynamic, Box<EvalAltResult>> {
        let mut ctx = LogicContext::for_record(record_from_dynamic(&fields)?);
        let v = logic_bridge::exec(obj, "put", &mut ctx).map_err(to_err)?;
        to_dynamic(&v)
    });
    engine.register_fn(
        "db_update",
        |obj: &str, id: i64, fields: Dynamic| -> Result<Dynamic, Box<EvalAltResult>> {
            let mut ctx = LogicContext::for_record(record_from_dynamic(&fields)?);
            ctx.set_arg("id", Value::from(id));
            let v = logic_bridge::exec(obj, "update", &mut ctx).map_err(to_err)?;
            to_dynamic(&v)
        },
    );
    engine.register_fn("db_delete", |obj: &str, id: i64| -> Result<(), Box<EvalAltResult>> {
        let mut ctx = LogicContext::for_id(id);
        logic_bridge::exec(obj, "delete", &mut ctx).map_err(to_err)?;
        Ok(())
    });

    engine
}
