fn run() -> Result<(), LogicError> {
    let op_roles = OpRoleLogic::create().select()?;
    let admin_role = op_roles.iter().find(|r| r.name() == "Administrator");
    if let Some(role) = admin_role {
        BaseTest::add_last_id("op_role", role.id());
    }

    let principals = PrincipalLogic::create().select()?;
    let user = os_user();
    let current = principals.iter().find(|p| p.username() == user);

    match current {
        None => {
            PrincipalTest::test_insert()?;
            let _principal_id = BaseTest::get_last_id("Principal");
            OpRoleMemberTest::test_insert()?;
        }
        Some(cp) => {
            BaseTest::add_last_id("principal", cp.id());

            let op_role_members = OpRoleMemberLogic::create().select()?;
            let admin_id = admin_role.map(|r| r.id()).unwrap_or_default();
            let membership = op_role_members
                .iter()
                .find(|m| m.principal_id() == cp.id() && m.op_role_id() == admin_id);

            if membership.is_none() {
                OpRoleMemberTest::test_insert()?;
            }
        }
    }

