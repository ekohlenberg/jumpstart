use base_test::BaseTest;

fn os_user() -> String {
    std::env::var("USER")
        .or_else(|_| std::env::var("USERNAME"))
        .unwrap_or_else(|_| "unknown".to_string())
}

/// Run a `select` through a logic type's dispatch entry and return the rows.
fn select_rows(
    exec: fn(&str, &mut LogicContext) -> Result<Value, LogicError>,
) -> Result<Vec<Value>, LogicError> {
    let mut ctx = LogicContext::new();
    let result = exec("select", &mut ctx)?;
    Ok(result.as_array().cloned().unwrap_or_default())
}

fn field_str(row: &Value, key: &str) -> String {
    row.get(key).and_then(|v| v.as_str()).unwrap_or_default().to_string()
}

fn field_i64(row: &Value, key: &str) -> i64 {
    row.get(key).and_then(|v| v.as_i64()).unwrap_or_default()
}

fn main() {
    if let Err(e) = run() {
        Logger::error(format!("Error executing test: {}", e));
        eprintln!("{}", e);
        std::process::exit(1);
    }
}

fn run() -> Result<(), LogicError> {
    let op_roles = select_rows(OpRoleLogic::exec)?;
    let admin_role = op_roles
        .iter()
        .find(|r| field_str(r, "name") == "Administrator");
    if let Some(role) = admin_role {
        BaseTest::add_last_id("op_role", field_i64(role, "id"));
    }

    let principals = select_rows(PrincipalLogic::exec)?;
    let user = os_user();
    let current = principals.iter().find(|p| field_str(p, "username") == user);

    match current {
        None => {
            PrincipalTest::test_insert()?;
            let _principal_id = BaseTest::get_last_id("Principal");
            OpRoleMemberTest::test_insert()?;
        }
        Some(cp) => {
            let cp_id = field_i64(cp, "id");
            BaseTest::add_last_id("principal", cp_id);

            let op_role_members = select_rows(OpRoleMemberLogic::exec)?;
            let admin_id = admin_role.map(|r| field_i64(r, "id")).unwrap_or_default();
            let has_membership = op_role_members.iter().any(|m| {
                field_i64(m, "principal_id") == cp_id && field_i64(m, "op_role_id") == admin_id
            });

            if !has_membership {
                OpRoleMemberTest::test_insert()?;
            }
        }
    }

