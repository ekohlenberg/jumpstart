<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OutputType>Exe</OutputType>
    <AssemblyName>scheduler</AssemblyName>
    <OutputPath>..\..\..\bin\scheduler</OutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.4.0" />
    <PackageReference Include="Quartz" Version="3.13.1" />
    <PackageReference Include="CronExpressionDescriptor" Version="2.27.0" />
    <!-- Auth0 JWT Bearer validation (inbound) -->
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="9.0.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\shared\common\common.csproj" />
    <ProjectReference Include="..\..\shared\domain\domain.csproj" />
    <ProjectReference Include="..\..\shared\logic\logic.csproj" />
     <ProjectReference Include="..\..\shared\persist\persist.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Npgsql" Version="8.0.3" />
  </ItemGroup>



</Project>
