{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "appsettings": {
    "logwriters": "@(Model.Name).LogFileWriter,@(Model.Name).LogTableWriter,@(Model.Name).LogConsoleWriter",
    "loglevel": "debug"
  },
  "Auth0": {
    "Domain":   "@(Model.Auth0Domain)",
    "Audience": "@(Model.Auth0Audience)"
  },
  "M2MClients": {
    "Scheduler": {
      "TokenEndpoint": "https://@(Model.Auth0Domain)/oauth/token",
      "ClientId":      "API_SERVER_M2M_CLIENT_ID",
      "ClientSecret":  "API_SERVER_M2M_CLIENT_SECRET",
      "Audience":      "https://@(Model.Name)-scheduler"
    }
  }
}
