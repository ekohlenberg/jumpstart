// Hand-written custom routes (FORCE=FALSE; created once under usr/server/api).
// Any request the generated router does not match is offered to
// `user_api::handle`, which returns Some(Response) to handle it or None to 404.
mod user_api {
    include!("../../../usr/server/api/user_api.rs");
}

const START_PORT: u16 = 5200;
const END_PORT: u16 = 5300;

fn main() {
    init_logging();
    let port = match find_port(START_PORT, END_PORT) {
        Some(p) => p,
        None => {
            Logger::error(format!("No available port in range {}-{}", START_PORT, END_PORT));
            std::process::exit(1);
        }
    };
    let addr = format!("0.0.0.0:{}", port);
    println!("API Server listening on http://{}", addr);
    Logger::info(format!("API server listening on http://{}", addr));

    // Self-register this node in core.server_node, mirroring the .NET API
    // server's background RegisterApiServer task. Spawned on its own thread so a
    // slow or unavailable database never blocks the server from serving requests.
    std::thread::spawn(move || register_api_server(port));

    // Keep SSE notification streams alive and prune disconnected clients.
    start_sse_heartbeat();

    rouille::start_server(addr, move |request| {
        // CORS preflight requests never carry Authorization, so answer them
        // before any auth check runs.
        if request.method().eq_ignore_ascii_case("OPTIONS") {
            return with_cors(request, Response::text(""));
        }

        // Identity: validate the Auth0 bearer token (RS256 against the
        // tenant's JWKS) and set the principal for the logic-layer
        // authorization check. Cleared on every request (even failures) so a
        // reused worker thread can't leak a previous request's user.
        match auth0::authenticate_inbound("api", request.header("Authorization")) {
            auth0::AuthOutcome::Authenticated(user) => {
                OpRoleMemberLogic::set_current_user(Some(user.as_str()));
            }
            auth0::AuthOutcome::Unconfigured => {
                // No "api" audience in ~/.<namespace>.json's `auth0` section
                // (see docs/auth0-setup.md) -- fall back to the pre-Auth0
                // X-User header so local development / jumptest keep working.
                OpRoleMemberLogic::set_current_user(request.header("X-User"));
            }
            auth0::AuthOutcome::Missing => {
                OpRoleMemberLogic::set_current_user(None);
                return with_cors(
                    request,
                    Response::text("missing bearer token").with_status_code(401),
                );
            }
            auth0::AuthOutcome::Invalid(reason) => {
                OpRoleMemberLogic::set_current_user(None);
                Logger::warning(format!("JWT validation failed: {}", reason));
                return with_cors(
                    request,
                    Response::text("invalid bearer token").with_status_code(401),
                );
            }
        }

        let response = handle(request);
        with_cors(request, response)
    });
}

fn find_port(start: u16, end: u16) -> Option<u16> {
    (start..=end).find(|&p| TcpListener::bind(("0.0.0.0", p)).is_ok())
}

/// Set the log level from the `JUMPSTART_LOG` env var (error|warning|info|debug).
/// Defaults to the Logger's built-in Info level when unset. Logs go to stderr
/// and to `api.log` in the working directory.
fn init_logging() {
    if let Ok(level) = std::env::var("JUMPSTART_LOG") {
        let level = match level.trim().to_ascii_lowercase().as_str() {
            "debug" => LogLevel::Debug,
            "warning" | "warn" => LogLevel::Warning,
            "error" => LogLevel::Error,
            _ => LogLevel::Info,
        };
        Logger::set_level(level);
        Logger::info(format!("log level set to {:?} from JUMPSTART_LOG", level));
    }

    // Make the database log writer available. It is invoked only when the
    // `database` writer is enabled via the `logwriters` config entry; the level
    // and active writers themselves are read from config inside the Logger.
    logic::register_db_log_writer();
}

/// Register this running API server as a `core.server_node` row, exactly as the
/// .NET API server does on startup. Uses the unchecked logic path because there
/// is no security principal at startup — the server is acting on its own behalf,
/// not handling a user request — so the authorization hook would otherwise deny
/// the write.
fn register_api_server(port: u16) {
    Util::populate_session_info();

    let computer_name = SessionInfo::get_value("ComputerName", Some("unknown")).unwrap_or_default();
    // Bound to all interfaces (IPAddress.Any in the .NET version); the concrete
    // address is resolved by the client when it connects.
    let ip_address = "0.0.0.0".to_string();
    let url = format!("http://{}:{}", computer_name, port);

    // Deliver this node's own notifications straight to the local SSE registry
    // (no loopback HTTP, so it works regardless of whether `url`'s hostname
    // resolves). The cross-node HTTP fan-out will skip this `url`.
    logic::notification::set_local_delivery(
        &url,
        Box::new(|domain: &str, id: i64, json: &str| {
            sse_publish_property_update(domain, id, json)
        }),
    );
    let username = SessionInfo::get_value("UserName", Some("")).unwrap_or_default();
    let user_domain = SessionInfo::get_value("UserDomain", Some("")).unwrap_or_default();
    let os_name = SessionInfo::get_value("OSName", Some("")).unwrap_or_default();
    let os_version = SessionInfo::get_value("OSVersion", Some("")).unwrap_or_default();
    let architecture = SessionInfo::get_value("Architecture", Some("")).unwrap_or_default();

    println!("==============================================");
    println!("API Server Registration");
    println!("==============================================");
    println!("API Server ID: {}:{}", computer_name, port);
    println!("Computer Name: {}", computer_name);
    println!("Port:          {}", port);
    println!("URL:           {}", url);
    println!("User:          {}@@{}", username, user_domain);
    println!("OS:            {} {} ({})", os_name, os_version, architecture);
    println!("==============================================");

    let mut record = BaseObject::new();
    record.set("hostname", serde_json::json!(computer_name));
    record.set(
        "server_node_type_id",
        serde_json::json!(ServerNodeType::ApiServer as i64),
    );
    record.set("ip_address", serde_json::json!(ip_address));
    record.set("port", serde_json::json!(port));
    record.set("url", serde_json::json!(url));
    record.set("username", serde_json::json!(username));
    record.set("user_domain", serde_json::json!(user_domain));
    record.set("os_name", serde_json::json!(os_name));
    record.set("os_version", serde_json::json!(os_version));
    record.set("architecture", serde_json::json!(architecture));
    record.set("registered_at", serde_json::json!(Util::now_timestamp()));
    record.set(
        "server_node_status_id",
        serde_json::json!(ServerNodeStatus::Online as i64),
    );
    record.set("is_active", serde_json::json!(1));
    record.set("created_by", serde_json::json!(username));

    let mut ctx = LogicContext::for_record(record);
    match ServerNodeLogic::exec_unchecked("put", &mut ctx) {
        Ok(_) => {
            let id = ctx.transaction.get("id").as_i64().unwrap_or_default();
            Logger::info(format!(
                "API server registered as ServerNode id {} ({})",
                id, url
            ));
        }
        Err(e) => Logger::error(format!("API server registration failed: {}", e)),
    }
}

fn with_cors(request: &Request, response: Response) -> Response {
    let origin = request.header("Origin").unwrap_or("*").to_string();
    response
        .with_additional_header("Access-Control-Allow-Origin", origin)
        .with_additional_header("Access-Control-Allow-Credentials", "true")
        .with_additional_header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
        .with_additional_header("Access-Control-Allow-Headers", "*")
}

fn handle(request: &Request) -> Response {
    let method = request.method().to_ascii_uppercase();
    let url = request.url();
    let path = url.trim_matches('/');
    let segs: Vec<&str> = if path.is_empty() { Vec::new() } else { path.split('/').collect() };

    if segs.is_empty() || !segs[0].eq_ignore_ascii_case("api") {
        return Response::empty_404();
    }
    let rest = &segs[1..];

    match (method.as_str(), rest.len()) {
        ("GET", 1) => exec_response(rest[0], "select", LogicContext::new()),
        ("POST", 1) => post_response(request, rest[0]),

        ("GET", 2) => {
            let (obj, seg) = (rest[0], rest[1]);
            if seg.eq_ignore_ascii_case("enum") {
                exec_response(obj, "enum", LogicContext::new())
            } else if obj.eq_ignore_ascii_case("notification") && seg.eq_ignore_ascii_case("stream") {
                sse_stream()
            } else if obj.eq_ignore_ascii_case("navmenu") && seg.eq_ignore_ascii_case("byparent") {
                nav_menu_by_parent(request)
            } else if let Ok(id) = seg.parse::<i64>() {
                exec_response(obj, "get", LogicContext::for_id(id))
            } else {
                Response::empty_404()
            }
        }
        ("PUT", 2) => match rest[1].parse::<i64>() {
            Ok(id) => put_response(request, rest[0], id),
            Err(_) => Response::empty_404(),
        },
        ("DELETE", 2) => match rest[1].parse::<i64>() {
            Ok(id) => exec_response(rest[0], "delete", LogicContext::for_id(id)),
            Err(_) => Response::empty_404(),
        },
        ("POST", 2) => {
            if rest[0].eq_ignore_ascii_case("notification") && rest[1].eq_ignore_ascii_case("publish") {
                notification_publish(request)
            } else {
                Response::empty_404()
            }
        }

        ("GET", 3) => {
            let (obj, a, b) = (rest[0], rest[1], rest[2]);
            if a.eq_ignore_ascii_case("view") {
                match b.parse::<i64>() {
                    Ok(id) => exec_response(obj, "view", LogicContext::for_id(id)),
                    Err(_) => Response::empty_404(),
                }
            } else if obj.eq_ignore_ascii_case("workflow") && a.eq_ignore_ascii_case("run") {
                match b.parse::<i64>() {
                    Ok(id) => workflow_run(id),
                    Err(_) => Response::empty_404(),
                }
            } else {
                match a.parse::<i64>() {
                    Ok(id) if b.eq_ignore_ascii_case("history") => {
                        exec_response(obj, "history", LogicContext::for_id(id))
                    }
                    Ok(id) => children_response(obj, id, b),
                    Err(_) => Response::empty_404(),
                }
            }
        }

        // Unmatched: offer the request to hand-written custom routes, else 404.
        _ => user_api::handle(request).unwrap_or_else(Response::empty_404),
    }
}

fn exec_response(obj: &str, method: &str, mut ctx: LogicContext) -> Response {
    match object_exec(obj, method, &mut ctx) {
        Ok(value) => Response::json(&value),
        Err(e) => error_response(e),
    }
}

fn post_response(request: &Request, obj: &str) -> Response {
    let body = match read_json(request) {
        Some(b) => b,
        None => return Response::text("invalid JSON body").with_status_code(400),
    };
    let mut ctx = LogicContext::for_record(record_from_value(&body));
    match object_exec(obj, "put", &mut ctx) {
        Ok(_) => Response::json(&with_id(body, ctx.transaction.get("id"))),
        Err(e) => error_response(e),
    }
}

fn put_response(request: &Request, obj: &str, id: i64) -> Response {
    let body = match read_json(request) {
        Some(b) => b,
        None => return Response::text("invalid JSON body").with_status_code(400),
    };
    let mut ctx = LogicContext::for_record(record_from_value(&body));
    ctx.set_arg("id", Value::from(id));
    match object_exec(obj, "update", &mut ctx) {
        Ok(_) => Response::json(&with_id(body, ctx.transaction.get("id"))),
        Err(e) => error_response(e),
    }
}

fn children_response(obj: &str, id: i64, child_key: &str) -> Response {
    // The route segment is "<childvar>_<childrole>"; the child-query suffix is
    // "<childvar>-<childrole>" (only the first underscore is the separator —
    // domain vars never contain underscores).
    let suffix = child_key.replacen('_', "-", 1);
    let mut ctx = LogicContext::for_id(id);
    ctx.set_arg("child_suffix", Value::String(suffix));
    match object_exec(obj, "children", &mut ctx) {
        Ok(value) => Response::json(&value),
        Err(e) => error_response(e),
    }
}

fn nav_menu_by_parent(request: &Request) -> Response {
    let parent_id: i64 = request
        .get_param("parent_id")
        .and_then(|s| s.parse().ok())
        .unwrap_or(0);
    let orderby = request
        .get_param("orderby")
        .unwrap_or_else(|| "ordinal".to_string());

    match NavMenuLogic::select_by_parent_id(parent_id, &orderby) {
        Ok(rows) => {
            let cols = NavMenu::columns();
            let arr: Vec<Value> = rows.iter().map(|o| to_typed_json(&o.base.data, &cols)).collect();
            Response::json(&Value::Array(arr))
        }
        Err(e) => {
            Logger::error(format!("nav menu by parent: {}", e));
            Response::text(e.to_string()).with_status_code(500)
        }
    }
}

fn notification_publish(request: &Request) -> Response {
    // A node's logic layer POSTs {DomainObjectName, InstanceId, JsonData} here
    // (see logic::notification). We stamp it with a timestamp and fan it out to
    // every connected SSE client as a PropertyUpdated event — the SSE analogue
    // of the .NET EventAggregator broadcasting over SignalR.
    if let Some(mut body) = read_json(request) {
        if let Value::Object(ref mut map) = body {
            map.insert("Timestamp".to_string(), Value::String(Util::now_iso8601()));
            sse_broadcast("PropertyUpdated", &body.to_string());
        }
    }
    Response::text("").with_status_code(200)
}

// ── Server-Sent Events: real-time object-change notifications ────────────────
// Connected web clients hold open a `GET /api/notification/stream` response.
// `notification_publish` pushes a PropertyUpdated event to every client; the
// client filters by domain object name. This replaces the .NET SignalR hub with
// a transport that both the .NET and Rust servers can serve and one Blazor
// client can consume.

// TODO(scalability): SSE fan-out is a single in-process registry, and each open
// connection holds a dedicated OS thread (the upgrade socket loop) plus a rouille
// worker. That caps concurrent clients per server at roughly the thread budget and
// keeps state process-local. To scale: (1) source events from a shared broker
// (Postgres LISTEN/NOTIFY or a message bus — see logic::notification) so any server
// can serve any client; (2) move the connection model to async I/O (e.g. an axum
// SSE endpoint on a tokio runtime) so thousands of idle streams cost almost nothing
// instead of a thread each; (3) put the API behind a load balancer with sticky or
// broker-backed routing. Until then this is fine for a modest number of clients.
fn sse_clients() -> &'static Mutex<Vec<Sender<Vec<u8>>>> {
    static CLIENTS: OnceLock<Mutex<Vec<Sender<Vec<u8>>>>> = OnceLock::new();
    CLIENTS.get_or_init(|| Mutex::new(Vec::new()))
}

/// Push a pre-formatted SSE payload to every client, dropping any whose receiver
/// has gone away (the client disconnected).
fn sse_send_raw(payload: Vec<u8>) {
    let mut clients = sse_clients().lock().unwrap();
    clients.retain(|tx| tx.send(payload.clone()).is_ok());
}

/// Broadcast a named SSE event with one JSON data line.
fn sse_broadcast(event: &str, data: &str) {
    let count = sse_clients().lock().unwrap().len();
    Logger::info(format!("SSE broadcast '{}' to {} client(s)", event, count));
    sse_send_raw(format!("event: {}\ndata: {}\n\n", event, data).into_bytes());
}

/// Build a PropertyUpdateMessage and broadcast it as a `PropertyUpdated` event.
/// Shared by the in-process delivery sink (logic::notification) and the HTTP
/// `notification_publish` handler so both produce an identical wire message.
fn sse_publish_property_update(domain: &str, instance_id: i64, json_data: &str) {
    let msg = serde_json::json!({
        "DomainObjectName": domain,
        "InstanceId": instance_id,
        "JsonData": json_data,
        "Timestamp": Util::now_iso8601(),
    });
    sse_broadcast("PropertyUpdated", &msg.to_string());
}

/// Open an SSE stream. The response body is fed by a channel; this request's
/// worker thread blocks writing it until the client disconnects.
fn sse_stream() -> Response {
    let (tx, rx) = std::sync::mpsc::channel::<Vec<u8>>();
    {
        let mut clients = sse_clients().lock().unwrap();
        clients.push(tx);
        Logger::info(format!("SSE client connected (total {})", clients.len()));
    }

    // rouille buffers reader-backed bodies (it computes Content-Length up front),
    // which never completes for an open-ended stream — so a plain streamed
    // response sends nothing, not even headers. Instead we take ownership of the
    // raw socket via the upgrade mechanism and write/flush SSE frames ourselves.
    Response {
        status_code: 200,
        headers: vec![
            ("Content-Type".into(), "text/event-stream".into()),
            ("Cache-Control".into(), "no-cache".into()),
            ("X-Accel-Buffering".into(), "no".into()),
        ],
        data: ResponseBody::empty(),
        upgrade: Some(Box::new(SseUpgrade { rx: Some(rx) })),
    }
}

/// Takes ownership of the client socket and streams SSE frames to it from the
/// channel, flushing after each write so events reach the browser immediately
/// (bypassing rouille/tiny_http's response buffering). Runs on its own thread —
/// one per connection — so it never holds a rouille worker thread.
struct SseUpgrade {
    rx: Option<Receiver<Vec<u8>>>,
}

impl Upgrade for SseUpgrade {
    fn build(&mut self, socket: Box<dyn rouille::ReadWrite + Send>) {
        let rx = match self.rx.take() {
            Some(r) => r,
            None => return,
        };
        std::thread::spawn(move || {
            let mut socket = socket;
            // Open the stream immediately.
            if socket.write_all(b": connected\n\n").is_err() || socket.flush().is_err() {
                return;
            }
            // Write each broadcast frame and flush so it is sent at once. A write
            // error means the client disconnected; the dropped receiver then lets
            // the next broadcast prune this client from the registry.
            while let Ok(bytes) = rx.recv() {
                if socket.write_all(&bytes).is_err() || socket.flush().is_err() {
                    break;
                }
            }
        });
    }
}

/// Periodically push an SSE comment so disconnected clients are detected (the
/// send fails once the receiver is gone) and intermediaries keep the stream open.
fn start_sse_heartbeat() {
    std::thread::spawn(|| loop {
        std::thread::sleep(Duration::from_secs(20));
        sse_send_raw(b": keepalive\n\n".to_vec());
    });
}

/// Dispatch a workflow run to the Scheduler, mirroring the .NET
/// `SchedulerClient.ExecuteAsync`: resolve an online Scheduler node from
/// `core.server_node`, POST the workflow id to its `/api/scheduler/execute`,
/// attaching an M2M bearer token when the API->Scheduler M2M client is
/// configured (see docs/auth0-m2m.md; unauthenticated otherwise, for local
/// development).
fn workflow_run(id: i64) -> Response {
    let url = match scheduler_url() {
        Some(u) => u,
        None => {
            Logger::error(format!(
                "workflow run {} requested, but no online Scheduler is registered",
                id
            ));
            return Response::text("no scheduler available").with_status_code(503);
        }
    };

    let endpoint = format!("{}/api/scheduler/execute", url.trim_end_matches('/'));
    let mut req = ureq::post(&endpoint).set("Content-Type", "application/json");
    match auth0::m2m_token("scheduler") {
        Ok(Some(token)) => req = req.set("Authorization", &format!("Bearer {}", token)),
        Ok(None) => {} // M2M not configured for the Scheduler -- call unauthenticated.
        Err(e) => Logger::warning(format!(
            "workflow run {}: M2M token fetch failed, calling unauthenticated: {}",
            id, e
        )),
    }

    match req.send_string(&id.to_string()) {
        Ok(_) => {
            Logger::info(format!("workflow run {} dispatched to scheduler at {}", id, url));
            Response::json(&serde_json::json!(id))
        }
        Err(e) => {
            Logger::error(format!("workflow run {} dispatch to scheduler failed: {}", id, e));
            Response::text("scheduler dispatch failed").with_status_code(502)
        }
    }
}

/// URL of an online Scheduler node in core.server_node, if any (parity with
/// the .NET SchedulerClient, which is constructed from the Scheduler's
/// ServerNode row).
fn scheduler_url() -> Option<String> {
    let sql = format!(
        "SELECT * FROM core.server_node \
         WHERE server_node_type_id = {} AND server_node_status_id = {} AND is_active = 1 \
         ORDER BY registered_at DESC LIMIT 1",
        ServerNodeType::Scheduler as i64,
        ServerNodeStatus::Online as i64
    );
    let rows = match persist::DBPersist::select(&sql, "default") {
        Ok(r) => r,
        Err(e) => {
            Logger::error(format!("scheduler lookup failed: {}", e));
            return None;
        }
    };
    rows.into_iter().find_map(|row| match row.get("url") {
        Some(Value::String(u)) if !u.is_empty() => Some(u.clone()),
        _ => None,
    })
}

fn error_response(e: LogicError) -> Response {
    match e {
        LogicError::Unauthorized(m) => Response::text(m).with_status_code(403),
        LogicError::Event(m) => Response::text(m).with_status_code(404),
        other => {
            Logger::error(format!("api error: {}", other));
            Response::text(other.to_string()).with_status_code(500)
        }
    }
}

fn read_json(request: &Request) -> Option<Value> {
    let mut body = request.data()?;
    let mut buf = String::new();
    body.read_to_string(&mut buf).ok()?;
    serde_json::from_str(&buf).ok()
}

fn record_from_value(body: &Value) -> BaseObject {
    let mut record = BaseObject::new();
    if let Value::Object(map) = body {
        for (k, v) in map {
            record.set(k, v.clone());
        }
    }
    record
}

fn with_id(mut body: Value, id: Value) -> Value {
    if let Value::Object(ref mut map) = body {
        map.insert("id".to_string(), id);
    }
    body
}
