#![allow(clippy::all)]

use std::collections::VecDeque;
use std::io::Read;
use std::net::TcpListener;
use std::sync::atomic::{AtomicBool, AtomicI64, Ordering};
use std::sync::{Mutex, OnceLock};
use std::time::Duration;

use common::{BaseObject, LogLevel, Logger, SessionInfo, Util};
use domain::execution_core::ExecStatus;
use domain::server_node_core::{ServerNodeStatus, ServerNodeType};
use domain::workflow_core::WorkflowType;
use logic::{object_exec_unchecked, LogicContext, ServerNodeLogic};
use rouille::{Request, Response};
use script::{ScriptContext, ScriptHost};
use serde_json::{json, Value};

const START_PORT: u16 = 5100;
const END_PORT: u16 = 5200;

/// core.server_node id assigned at registration (0 until registered).
static THIS_NODE_ID: AtomicI64 = AtomicI64::new(0);
/// Ensures only one execution thread is ever started.
static EXEC_THREAD_RUNNING: AtomicBool = AtomicBool::new(false);

fn main() {
    init_logging();

    let port = match find_port(START_PORT, END_PORT) {
        Some(p) => p,
        None => {
            Logger::error(format!("No available port in range {}-{}", START_PORT, END_PORT));
            std::process::exit(1);
        }
    };
    let addr = format!("0.0.0.0:{}", port);
    println!("ScriptAgent listening on http://{}", addr);
    Logger::info(format!("ScriptAgent listening on http://{}", addr));

    // Mark the node Offline if we are interrupted/terminated.
    install_shutdown_handler();

    // Self-register as an Agent node (on its own thread so a slow DB never blocks
    // startup), and start the background execution thread.
    std::thread::spawn(move || register_script_agent(port));
    start_execution_thread();

    rouille::start_server(addr, move |request| {
        let response = handle(request);
        with_cors(request, response)
    });
}

// ── infrastructure (mirrors the API server) ─────────────────────────────────

fn find_port(start: u16, end: u16) -> Option<u16> {
    (start..=end).find(|&p| TcpListener::bind(("0.0.0.0", p)).is_ok())
}

/// Set the log level from JUMPSTART_LOG (error|warning|info|debug); default Info.
fn init_logging() {
    if let Ok(level) = std::env::var("JUMPSTART_LOG") {
        let level = match level.trim().to_ascii_lowercase().as_str() {
            "debug" => LogLevel::Debug,
            "warning" | "warn" => LogLevel::Warning,
            "error" => LogLevel::Error,
            _ => LogLevel::Info,
        };
        Logger::set_level(level);
    }
}

fn with_cors(request: &Request, response: Response) -> Response {
    let origin = request.header("Origin").unwrap_or("*").to_string();
    response
        .with_additional_header("Access-Control-Allow-Origin", origin)
        .with_additional_header("Access-Control-Allow-Credentials", "true")
        .with_additional_header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
        .with_additional_header("Access-Control-Allow-Headers", "*")
}

fn install_shutdown_handler() {
    let result = ctrlc::set_handler(|| {
        Logger::info("scriptagent: shutdown signal received, marking node Offline");
        set_node_offline();
        std::process::exit(0);
    });
    if let Err(e) = result {
        Logger::warning(format!("scriptagent: could not install shutdown handler: {}", e));
    }
}

// ── REST routing ─────────────────────────────────────────────────────────────

fn handle(request: &Request) -> Response {
    if request.method().eq_ignore_ascii_case("OPTIONS") {
        return Response::text("");
    }

    let method = request.method().to_ascii_uppercase();
    let url = request.url();
    let path = url.trim_matches('/');
    let segs: Vec<&str> = if path.is_empty() { Vec::new() } else { path.split('/').collect() };

    if segs.len() < 3
        || !segs[0].eq_ignore_ascii_case("api")
        || !segs[1].eq_ignore_ascii_case("scriptagent")
    {
        return Response::empty_404();
    }
    let action = segs[2].to_ascii_lowercase();
    let id = segs.get(3).and_then(|s| s.parse::<i64>().ok());

    match (method.as_str(), action.as_str()) {
        // ── Job execution ──
        ("POST", "execute") => {
            let wid = read_long_body(request).or(id).unwrap_or(0);
            agent_execute(wid);
            Response::json(&json!(wid))
        }
        ("POST", "validate") => Response::json(&json!({ "valid": true })),
        ("POST", "prepare") => {
            let wid = read_long_body(request).or(id).unwrap_or(0);
            Response::json(&json!(wid))
        }
        ("POST", "cleanup") | ("POST", "retry") => {
            Logger::info(format!("scriptagent: {} {:?}", action, id));
            Response::text("")
        }

        // ── Process management ──
        ("POST", "stop") | ("POST", "kill") | ("POST", "restart") | ("POST", "pause")
        | ("POST", "resume") => {
            Logger::info(format!("scriptagent: {} {:?}", action, id));
            Response::text("")
        }

        // ── Status & reporting ──
        ("GET", "status") => Response::json(&json!({ "workflowId": id.unwrap_or(0), "status": "unknown" })),
        ("POST", "heartbeat") | ("POST", "report") | ("POST", "log") | ("POST", "metrics") => {
            Logger::info(format!("scriptagent: {}", action));
            Response::text("")
        }

        // ── Resource management ──
        ("GET", "capabilities") => {
            Response::json(&json!({ "cpu": "unknown", "memory": "unknown", "capabilities": [] }))
        }
        ("POST", "allocate") => {
            let wid = read_long_body(request).unwrap_or(0);
            Response::json(&json!(wid))
        }
        ("POST", "release") => Response::text(""),

        // ── Communication ──
        ("GET", "ping") => Response::json(&json!({ "status": "alive", "timestamp": Util::now_iso8601() })),
        ("POST", "acknowledge") | ("POST", "notify") => Response::text(""),
        ("POST", "request") => Response::json(&json!({ "status": "pending" })),

        // ── System ──
        ("POST", "shutdown") | ("POST", "reload") | ("POST", "update") => {
            Logger::info(format!("scriptagent: {}", action));
            Response::text("")
        }
        ("GET", "diagnose") => Response::json(&json!({ "status": "healthy", "diagnostics": [] })),
        ("GET", "health") => Response::json(&json!({ "status": "healthy" })),

        // ── Security ──
        ("POST", "authenticate") => Response::json(&json!({ "authenticated": true, "token": "placeholder" })),
        ("POST", "authorize") => Response::json(&json!({ "authorized": true })),

        // ── Standard ──
        ("GET", "executions") => Response::json(&json!([])),
        ("GET", "execution") => Response::json(&json!({ "workflowId": id.unwrap_or(0), "status": "unknown" })),
        ("POST", "execution") => Response::json(&json!(0)), // insert (stub)
        ("PUT", "execution") => Response::text(""),         // update (stub)
        ("DELETE", "execution") => Response::text(""),      // delete (stub)
        ("GET", "info") => Response::json(&json!({
            "hostname": SessionInfo::get_value("ComputerName", Some("unknown")).unwrap_or_default(),
            "status": "online",
            "capabilities": []
        })),

        _ => Response::empty_404(),
    }
}

fn read_body(request: &Request) -> Option<Value> {
    let mut s = String::new();
    request.data()?.read_to_string(&mut s).ok()?;
    serde_json::from_str(&s).ok()
}

/// The execute/allocate/prepare endpoints take a bare JSON number (the id).
fn read_long_body(request: &Request) -> Option<i64> {
    read_body(request).and_then(|v| v.as_i64())
}

// ── execution engine ─────────────────────────────────────────────────────────

fn workflow_queue() -> &'static Mutex<VecDeque<i64>> {
    static Q: OnceLock<Mutex<VecDeque<i64>>> = OnceLock::new();
    Q.get_or_init(|| Mutex::new(VecDeque::new()))
}

fn agent_execute(workflow_id: i64) {
    Logger::info(format!("scriptagent: execute requested for workflow {}", workflow_id));
    workflow_queue().lock().unwrap().push_back(workflow_id);
    start_execution_thread();
}

/// Start the single background thread that drains the workflow queue. Idempotent.
fn start_execution_thread() {
    if EXEC_THREAD_RUNNING.swap(true, Ordering::SeqCst) {
        return; // already running
    }
    std::thread::spawn(|| {
        Logger::info("scriptagent: execution thread started");
        loop {
            let next = workflow_queue().lock().unwrap().pop_front();
            match next {
                Some(workflow_id) => {
                    Logger::info(format!("scriptagent: processing workflow {}", workflow_id));
                    update_agent_status(ServerNodeStatus::Busy);
                    if let Err(e) = execute_workflow(workflow_id) {
                        Logger::error(format!("scriptagent: workflow {} failed: {}", workflow_id, e));
                    } else {
                        Logger::info(format!("scriptagent: completed workflow {}", workflow_id));
                    }
                    update_agent_status(ServerNodeStatus::Online);
                }
                None => std::thread::sleep(Duration::from_millis(100)),
            }
        }
    });
}

/// Run one workflow's script (mirrors .NET ScriptAgentLogic.ExecuteWorkflow).
fn execute_workflow(workflow_id: i64) -> Result<(), String> {
    let wf = exec_get("workflow", workflow_id)?.ok_or_else(|| "workflow not found".to_string())?;

    if jval_i64(&wf, "workflow_type_id") != WorkflowType::Process as i64 {
        return Err("workflow is not a process".to_string());
    }
    let process_id = jval_i64(&wf, "process_id");
    let process = exec_get("process", process_id)?.ok_or_else(|| "process not found".to_string())?;
    let script_id = jval_i64(&process, "script_id");
    if script_id == 0 {
        return Err("process has no script".to_string());
    }

    // Mark the workflow Executing and notify.
    let mut wf_obj = base_object_from_value(&wf);
    wf_obj.set("exec_status_id", json!(ExecStatus::Executing as i64));
    wf_obj.set("last_start_time", json!(Util::now_iso8601()));
    update_object("workflow", workflow_id, &wf_obj)?;
    publish_workflow_change(workflow_id, &wf_obj);

    // Load and run the script.
    let script = exec_get("script", script_id)?.ok_or_else(|| "script not found".to_string())?;
    let script_obj = base_object_from_value(&script);
    let mut sctx = ScriptContext::with_transaction(base_object_from_value(&wf));

    let status = match ScriptHost::invoke(&mut sctx, &script_obj) {
        Ok(()) => {
            if sctx.ret_code != 0 {
                Logger::error(format!("scriptagent: script returned code {}", sctx.ret_code));
                ExecStatus::Failed
            } else if let Some(err) = &sctx.script_exception {
                Logger::error(format!("scriptagent: script exception: {}", err));
                ExecStatus::Failed
            } else {
                ExecStatus::Completed
            }
        }
        Err(e) => {
            Logger::error(format!("scriptagent: script execution error: {}", e));
            ExecStatus::Failed
        }
    };

    // Write the final status back and notify.
    wf_obj.set("exec_status_id", json!(status as i64));
    wf_obj.set("last_end_time", json!(Util::now_iso8601()));
    update_object("workflow", workflow_id, &wf_obj)?;
    publish_workflow_change(workflow_id, &wf_obj);

    Ok(())
}

/// The agent updates rows on the unchecked path (no principal), which bypasses
/// the proxy's notification hook — so publish the change explicitly here, the
/// same way the proxy would, so web clients watching Workflow update live.
fn publish_workflow_change(workflow_id: i64, wf_obj: &BaseObject) {
    logic::notification::publish("Workflow", workflow_id, wf_obj.to_json());
}

// ── registration / status ────────────────────────────────────────────────────

fn register_script_agent(port: u16) {
    Util::populate_session_info();

    let computer_name = SessionInfo::get_value("ComputerName", Some("unknown")).unwrap_or_default();
    let ip_address = "0.0.0.0".to_string();
    let url = format!("http://{}:{}", computer_name, port);
    let username = SessionInfo::get_value("UserName", Some("")).unwrap_or_default();
    let user_domain = SessionInfo::get_value("UserDomain", Some("")).unwrap_or_default();
    let os_name = SessionInfo::get_value("OSName", Some("")).unwrap_or_default();
    let os_version = SessionInfo::get_value("OSVersion", Some("")).unwrap_or_default();
    let architecture = SessionInfo::get_value("Architecture", Some("")).unwrap_or_default();

    println!("==============================================");
    println!("ScriptAgent Registration");
    println!("==============================================");
    println!("ScriptAgent ID: {}:{}", computer_name, port);
    println!("URL:            {}", url);
    println!("User:           {}@@{}", username, user_domain);
    println!("OS:             {} {} ({})", os_name, os_version, architecture);
    println!("==============================================");

    let mut record = BaseObject::new();
    record.set("hostname", json!(computer_name));
    record.set("server_node_type_id", json!(ServerNodeType::Agent as i64));
    record.set("ip_address", json!(ip_address));
    record.set("port", json!(port));
    record.set("url", json!(url));
    record.set("username", json!(username));
    record.set("user_domain", json!(user_domain));
    record.set("os_name", json!(os_name));
    record.set("os_version", json!(os_version));
    record.set("architecture", json!(architecture));
    record.set("registered_at", json!(Util::now_iso8601()));
    record.set("server_node_status_id", json!(ServerNodeStatus::Online as i64));
    record.set("is_active", json!(1));
    record.set("created_by", json!(username));

    let mut ctx = LogicContext::for_record(record);
    match ServerNodeLogic::exec_unchecked("put", &mut ctx) {
        Ok(_) => {
            let id = ctx.transaction.get("id").as_i64().unwrap_or_default();
            THIS_NODE_ID.store(id, Ordering::SeqCst);
            Logger::info(format!("scriptagent registered as ServerNode id {} ({})", id, url));
        }
        Err(e) => Logger::error(format!("scriptagent registration failed: {}", e)),
    }
}

fn update_agent_status(status: ServerNodeStatus) {
    let node_id = THIS_NODE_ID.load(Ordering::SeqCst);
    if node_id == 0 {
        return;
    }
    if let Ok(Some(node)) = exec_get("servernode", node_id) {
        let mut obj = base_object_from_value(&node);
        obj.set("server_node_status_id", json!(status as i64));
        let _ = update_object("servernode", node_id, &obj);
    }
}

fn set_node_offline() {
    let node_id = THIS_NODE_ID.load(Ordering::SeqCst);
    if node_id == 0 {
        Logger::info("scriptagent: no registered node to mark Offline");
        return;
    }
    if let Ok(Some(node)) = exec_get("servernode", node_id) {
        let mut obj = base_object_from_value(&node);
        obj.set("server_node_status_id", json!(ServerNodeStatus::Offline as i64));
        let _ = update_object("servernode", node_id, &obj);
        Logger::info(format!("scriptagent: node {} marked Offline", node_id));
    }
}

// ── logic helpers (unchecked: agent has no security principal) ────────────────

fn exec_get(object: &str, id: i64) -> Result<Option<Value>, String> {
    let mut ctx = LogicContext::for_id(id);
    match object_exec_unchecked(object, "get", &mut ctx) {
        Ok(Value::Null) => Ok(None),
        Ok(v) => Ok(Some(v)),
        Err(e) => Err(format!("{}", e)),
    }
}

fn update_object(object: &str, id: i64, record: &BaseObject) -> Result<Value, String> {
    let mut ctx = LogicContext::for_record(record.clone());
    ctx.set_arg("id", json!(id));
    object_exec_unchecked(object, "update", &mut ctx).map_err(|e| format!("{}", e))
}

fn base_object_from_value(value: &Value) -> BaseObject {
    let mut obj = BaseObject::new();
    if let Value::Object(map) = value {
        for (k, v) in map {
            obj.set(k, v.clone());
        }
    }
    obj
}

fn jval_i64(value: &Value, key: &str) -> i64 {
    value.get(key).and_then(|v| v.as_i64()).unwrap_or(0)
}
