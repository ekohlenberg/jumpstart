<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OutputType>Exe</OutputType>
    <AssemblyName>test-impexp</AssemblyName>
  </PropertyGroup>

  <!-- Copy generated test data CSVs to build output alongside the executable -->
  <ItemGroup>
    <Content Include="*.csv">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\shared\common\common.csproj" />
    <ProjectReference Include="..\..\shared\domain\domain.csproj" />
    <ProjectReference Include="..\..\shared\logic\logic.csproj" />
    <ProjectReference Include="..\..\shared\persist\persist.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CsvHelper" Version="33.0.1" />
    <PackageReference Include="Npgsql" Version="8.0.3" />
  </ItemGroup>

</Project>
