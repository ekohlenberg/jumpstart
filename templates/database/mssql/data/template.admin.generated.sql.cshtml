-- =====================================
-- 1) Create Admin Principal
-- =====================================
DECLARE @@principal_id BIGINT, @@password_id BIGINT, @@role_id BIGINT, @@role_map_id BIGINT, @@role_member_id BIGINT;

SELECT @@principal_id = NEXT VALUE FOR app.principal_identity;
INSERT INTO app.principal(
    id,
    txn_id,
    first_name,
    last_name,
    username,
    email,
    created_date,
    last_login_date,
    is_active,
    created_by,
    last_updated,
    last_updated_by
)
VALUES (
    @@principal_id,
    @@principal_id,
    'Admin',
    'Principal',
    'admin',
    'admin@@mydomain.com',
    GETDATE(),
    GETDATE(),
    1,
    'system',
    GETDATE(),
    'system'
);

SELECT @@password_id = NEXT VALUE FOR sec.principal_password_identity;

WITH admin_principal_id AS (
    SELECT id FROM app.principal WHERE username = 'admin' AND is_active = 1
)
INSERT INTO sec.principal_password(
    id, txn_id, principal_id, password_hash, expiry, needs_reset, is_active, created_by, last_updated, last_updated_by)
SELECT @@password_id,
    @@password_id,
    admin_principal_id.id,
    CAST(FLOOR(RAND(CHECKSUM(NEWID())) * 100000 + 1) AS NVARCHAR(10)),
    GETDATE(),
    1,
    1,
    SYSTEM_USER,
    GETDATE(),
    SYSTEM_USER
FROM admin_principal_id;

-- =====================================
-- 2) Create Admin Role
-- =====================================
SELECT @@role_id = NEXT VALUE FOR sec.op_role_identity;
INSERT INTO sec.op_role(
    id,
    txn_id,
    name,
    is_active,
    created_by,
    last_updated,
    last_updated_by
)
VALUES (
    @@role_id,
    @@role_id,
    'Administrator',
    1,
    'system',
    GETDATE(),
    'system'
);

-- =====================================
-- 3) Grant All Operations to Admin Role
--    (Map every operation in sec.operation to the admin role)
--    CROSS APPLY ensures NEXT VALUE FOR is called once per row so id = txn_id
-- =====================================
DECLARE @@admin_role_id BIGINT;
SELECT @@admin_role_id = id FROM sec.op_role WHERE name = 'Administrator' AND is_active = 1;

INSERT INTO sec.op_role_map(
    id,
    txn_id,
    op_id,
    op_role_id,
    is_active,
    created_by,
    last_updated,
    last_updated_by
)
SELECT seq.n, seq.n, op.id, @@admin_role_id, 1, 'system', GETDATE(), 'system'
FROM sec.operation op
CROSS APPLY (SELECT NEXT VALUE FOR sec.op_role_map_identity AS n) seq
WHERE op.is_active = 1;

-- =====================================
-- 4) Map Admin Principal to Admin Role
--    Using sub-selects on app.principal (by username)
--    and sec.op_role (by name)
-- =====================================
SELECT @@role_member_id = NEXT VALUE FOR sec.op_role_member_identity;

WITH admin_principal_id AS (
    SELECT id FROM app.principal WHERE username = 'admin' AND is_active = 1
),
admin_role_id AS (
    SELECT id FROM sec.op_role WHERE name = 'Administrator' AND is_active = 1
)
INSERT INTO sec.op_role_member(
    id,
    txn_id,
    principal_id,
    op_role_id,
    is_active,
    created_by,
    last_updated,
    last_updated_by
)
SELECT
    @@role_member_id,
    @@role_member_id,
    admin_principal_id.id,
    admin_role_id.id,
    1,
    'system',
    GETDATE(),
    'system'
FROM admin_principal_id
CROSS JOIN admin_role_id;

-- =====================================
-- Done!
-- =====================================
