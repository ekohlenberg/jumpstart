-- =====================================
-- 1) Create Account for Current OS Principal
-- e.g.
-- \set afile `echo "$outputdir/a.csv"`
-- COPY (SELECT * FROM a) TO :'afile';
-- =====================================
\set os_user `echo $LOGNAME`

INSERT INTO app."principal"(id, txn_id, first_name, last_name, username, email, created_date, last_login_date, is_active, created_by, last_updated, last_updated_by)
SELECT n, n, 'Current', 'Principal', :'os_user', :'os_user' || '@@mydomain.com', now(), now(), 1, 'system', now(), 'system'
FROM (SELECT nextval('app.principal_identity') n) t;

WITH os_user_principal_id AS (
    SELECT id FROM app."principal" WHERE username = :'os_user' AND is_active = 1
)
INSERT INTO sec.principal_password(id, txn_id, principal_id, password_hash, expiry, needs_reset, is_active, created_by, last_updated, last_updated_by)
SELECT n, n, os_user_principal_id.id, (floor(random() * 100000 + 1))::int::varchar, current_timestamp, 1, 1, current_user, current_timestamp, current_user
FROM os_user_principal_id
CROSS JOIN LATERAL (SELECT nextval('sec.principal_password_identity') AS n) seq;



-- =====================================
-- 2) Map os_user Principal to os_user Role
--    Using sub-selects on sec."principal" (by username)
--    and sec.op_role (by name)
-- =====================================
WITH os_user_principal_id AS (
    SELECT id FROM app."principal" WHERE username = :'os_user' AND is_active = 1
),
os_user_role_id AS (
    SELECT id FROM sec.op_role WHERE name = 'Administrator' AND is_active = 1
)
INSERT INTO sec.op_role_member(id, txn_id, principal_id, op_role_id, is_active, created_by, last_updated, last_updated_by)
SELECT n, n, os_user_principal_id.id, os_user_role_id.id, 1, 'system', now(), 'system'
FROM os_user_principal_id
CROSS JOIN os_user_role_id
CROSS JOIN LATERAL (SELECT nextval('sec.op_role_member_identity') AS n) seq;

-- =====================================
-- Done!
-- =====================================
