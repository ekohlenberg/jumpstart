-- =====================================
-- 1) Create Admin Principal
-- =====================================
INSERT INTO app."principal"(id, txn_id, first_name, last_name, username, email, created_date, last_login_date, is_active, created_by, last_updated, last_updated_by)
SELECT n, n, 'Admin', 'Principal', 'admin', 'admin@mydomain.com', now(), now(), 1, 'system', now(), 'system'
FROM (SELECT nextval('app.principal_identity') n) t;

WITH admin_principal_id AS (
    SELECT id FROM app."principal" WHERE username = 'admin' AND is_active = 1
)
INSERT INTO sec.principal_password(id, txn_id, principal_id, password_hash, expiry, needs_reset, is_active, created_by, last_updated, last_updated_by)
SELECT n, n, admin_principal_id.id, (floor(random() * 100000 + 1))::int::varchar, current_timestamp, 1, 1, current_user, current_timestamp, current_user
FROM admin_principal_id
CROSS JOIN LATERAL (SELECT nextval('sec.principal_password_identity') AS n) seq;

-- =====================================
-- 2) Create Admin Role
-- =====================================
INSERT INTO sec.op_role(id, txn_id, name, is_active, created_by, last_updated, last_updated_by)
SELECT n, n, 'Administrator', 1, 'system', now(), 'system'
FROM (SELECT nextval('sec.op_role_identity') n) t;

-- =====================================
-- 3) Grant All Operations to Admin Role
--    (Map every operation in sec.operation to the admin role)
--    Using a sub-select on sec.op_role to fetch the ID by "name"
-- =====================================
WITH admin_role_id AS (
    SELECT id FROM sec.op_role WHERE name = 'Administrator' AND is_active = 1
)
INSERT INTO sec.op_role_map(id, txn_id, op_id, op_role_id, is_active, created_by, last_updated, last_updated_by)
SELECT n, n, op.id, admin_role_id.id, 1, 'system', now(), 'system'
FROM sec.operation op
CROSS JOIN admin_role_id
CROSS JOIN LATERAL (SELECT nextval('sec.op_role_map_identity') AS n) seq
WHERE op.is_active = 1;

-- =====================================
-- 4) Map Admin Principal to Admin Role
--    Using sub-selects on sec."principal" (by username)
--    and sec.op_role (by name)
-- =====================================
WITH admin_principal_id AS (
    SELECT id FROM app."principal" WHERE username = 'admin' AND is_active = 1
),
admin_role_id AS (
    SELECT id FROM sec.op_role WHERE name = 'Administrator' AND is_active = 1
)
INSERT INTO sec.op_role_member(id, txn_id, principal_id, op_role_id, is_active, created_by, last_updated, last_updated_by)
SELECT n, n, admin_principal_id.id, admin_role_id.id, 1, 'system', now(), 'system'
FROM admin_principal_id
CROSS JOIN admin_role_id
CROSS JOIN LATERAL (SELECT nextval('sec.op_role_member_identity') AS n) seq;

-- =====================================
-- Done!
-- =====================================
