-- =====================================
-- Generate SELECT queries for many-to-many ("map") relationship checklists
-- =====================================
@using System.Linq;
@using System.Collections.Generic;
@using jumpstart;

@{
    var metaObject = (MetaObject)Model;

    var domainObj = metaObject.DomainObj;
    var tableName = metaObject.TableName;
    var schemaName = metaObject.SchemaName;

    // Get all map relationships anchored on this object (see
    // MetaObject.MapRelationships / MetaObject.ProcessMapRelationships)
    var mapRelationships = metaObject.MapRelationships;

    if (mapRelationships.Count > 0)
    {
        <text>
-- =====================================
-- Map-relationship queries for @(domainObj) (@(schemaName).@(tableName))
-- =====================================

        </text>

        foreach (var map in mapRelationships)
        {
            var mapObject = map.MapObject;
            var selfAttribute = map.SelfAttribute;
            var otherAttribute = map.OtherAttribute;
            var otherObject = map.OtherObject;
            var role = map.Role;
            var otherLabel = map.Label;

            var mapSchema = mapObject.SchemaName;
            var mapTable = mapObject.TableName;
            var otherSchema = otherObject.SchemaName;
            var otherTable = otherObject.TableName;
            var otherDomainVar = otherObject.DomainVar;

            // Build a label expression from the other object's RWK columns,
            // same convention as ProcessView's synthesized RWK columns --
            // falls back to the id cast to text if the other object has no
            // RWK columns defined.
            // The whole INSERT statement below is emitted as raw literal text,
            // and sql_text's own value is itself single-quote-delimited within
            // that INSERT -- so any literal "'" this expression needs to end
            // up in the stored sql_text (the CONCAT_WS separator) has to be
            // doubled ('') here to survive that one level of SQL string
            // escaping, same as any other apostrophe inside a quoted literal.
            var rwkAttrs = otherObject.Attributes.Where(a => a.RWK == "1").ToList();
            string labelExpression = rwkAttrs.Count > 0
                ? "CONCAT_WS('' '', " + string.Join(", ", rwkAttrs.Select(a => otherTable + "." + a.Name)) + ")"
                : otherTable + ".id::text";

            <text>
-- Map relationship: @(otherLabel) (@(role)), via @(mapSchema).@(mapTable)
INSERT INTO core.sql (id, txn_id, name, sql_text, description, last_updated, last_updated_by, is_active, data_source_id)
SELECT n, n,
    '@(schemaName).@(tableName)-map-@(otherDomainVar)-@(role)',
    'SELECT
        @(otherTable).id AS id,
        @(labelExpression) AS label,
        CASE WHEN @(mapTable).id IS NOT NULL THEN 1 ELSE 0 END AS mapped
    FROM @(otherSchema).@(otherTable)
    LEFT JOIN @(mapSchema).@(mapTable) ON @(mapTable).@(otherAttribute.Name) = @(otherTable).id AND @(mapTable).@(selfAttribute.Name) = ^(id) AND @(mapTable).is_active = 1
    WHERE @(otherTable).is_active = 1
    ORDER BY @(otherTable).id;',
    'Select @(otherLabel) options for @(domainObj), flagged as mapped where a @(mapTable) row already links them',
    NOW(),
    CURRENT_USER,
    1,
    (SELECT id FROM core.data_source WHERE name = 'default' AND is_active = 1)
FROM (SELECT nextval('core.sql_identity') n) t;

            </text>
        }
    }
    else
    {
        <text>
-- =====================================
-- No map relationships found for @(domainObj) (@(schemaName).@(tableName))
-- =====================================

        </text>
    }
}
